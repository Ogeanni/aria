OPENAI_API_KEY=sk-ant-your-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
SERPAPI_KEY=your-serpapi-key-here

# ── Operating Mode ────────────────────────────────────────────────────
# false = uses live SerpAPI data
# true  = uses price simulator (no API credits consumed)
DEMO_MODE=false

# ── Database ──────────────────────────────────────────────────────────
# Railway injects this automatically — do not set on Railway
# For Docker Compose on a VPS, set this manually:
DATABASE_URL=postgresql://aria_user:CHANGE_ME@postgres:5432/aria

# Docker Compose only — Railway manages Postgres itself
POSTGRES_DB=aria
POSTGRES_USER=aria_user
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────
# Railway injects this automatically — do not set on Railway
# For Docker Compose on a VPS:
REDIS_URL=redis://redis:6379/0

# ── Agent Behaviour ───────────────────────────────────────────────────
AGENT_SCHEDULE_MINUTES=60
AGENT_AUTO_APPROVE_MAX_PCT=10
AGENT_HUMAN_REVIEW_THRESHOLD_PCT=10
AGENT_MAX_ITERATIONS=6

# ── Monitoring ────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Langfuse LLM tracing — sign up free at langfuse.com (optional)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Slack or Teams alert webhook (optional)
ALERT_WEBHOOK_URL=

# ── Google Trends ─────────────────────────────────────────────────────
TRENDS_REGION=US
TRENDS_TIMEFRAME=today 12-m