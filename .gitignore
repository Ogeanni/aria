# ─────────────────────────────────────────────────────────────────────
# ARIA .gitignore
# ─────────────────────────────────────────────────────────────────────

# ── SECRETS — NEVER commit these ─────────────────────────────────────
.env
.env.local
.env.*.local
# Keep the templates — they are safe to commit
!.env.example
!.env.production

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ── Virtual environments ──────────────────────────────────────────────
venv/
env/
.venv/
ENV/
.conda/

# ── ML model artifacts ────────────────────────────────────────────────
# Large binary files — regenerated by running the training pipeline
models/saved_models/*.ubj
models/saved_models/*.json
models/prophet/saved_models/*.pkl
models/prophet/saved_models/*.json
# Keep the directory structure
!models/saved_models/.gitkeep
!models/prophet/saved_models/.gitkeep

# ── Data directories ──────────────────────────────────────────────────
# Populated at runtime — not source code
data/raw/
data/processed/
data/cache/
# Keep the directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/cache/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────
logs/
*.log
*.jsonl
!logs/.gitkeep

# ── Results ───────────────────────────────────────────────────────────
results/
!results/.gitkeep

# ── Local databases ───────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Testing ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDEs ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.spyderproject.cfg
.ropeproject

# ── OS ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Documentation artifacts ───────────────────────────────────────────
*.docx
*.pdf

# ── Node (local tooling) ──────────────────────────────────────────────
node_modules/
*.js.map